# ── Database (Neon Postgres via Netlify) ──
# On Netlify, NETLIFY_DATABASE_URL is injected automatically.
# For local development, set one of these:
NETLIFY_DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# ── Anthropic (Claude AI — screenplay parsing, script doctor, dialogue polish) ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── macOS Local Dev TLS Fix ──
# Export system CA certs: security find-certificate -a -p /System/Library/Keychains/SystemRootCertificates.keychain > /tmp/ca-certs.pem
NODE_EXTRA_CA_CERTS=/tmp/ca-certs.pem

# ── Optional: Site URL for meta tags ──
# NEXT_PUBLIC_SITE_URL=https://screenplay-studio.netlify.app
